[Unit]
Description=Smart Checkout Vision System
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/s-check
Environment=QT_QPA_PLATFORM=xcb
Environment=DISPLAY=:0
ExecStart=/home/pi/s-check/.venv/bin/python3 main.py
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
